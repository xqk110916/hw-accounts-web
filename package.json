{
  "name": "zc-fontend-cli",
  "version": "1.0.0",
  "description": "ZC标准前端框架cli",
  "author": "吴明伟",
  "license": "MIT",
  "scripts": {
    "dev": "vue-cli-service serve",
    "build:prod": "vue-cli-service build --mode production",
    "build": "vue-cli-service build --mode test",
    "lint": "eslint --ext .js,.vue src",
    "release-tag": "standard-version --release-as v0.1.0-alpha && git push --follow-tags",
    "release": "standard-version --release-as v0.1.0-alpha --infile=changelog.md --skip.tag=true && git push"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "src/**/*.{js,vue}": [
      "eslint --fix",
      "git add"
    ]
  },
  "keywords": [
    "vue",
    "admin",
    "dashboard",
    "element-ui",
    "boilerplate",
    "admin-template",
    "management-system"
  ],
  "repository": {
    "type": "git",
    "url": ""
  },
  "dependencies": {
    "@vue/babel-helper-vue-jsx-merge-props": "^1.4.0",
    "@vue/babel-preset-app": "^5.0.8",
    "async-validator": "1.11.5",
    "axios": "0.21.0",
    "babel-cli": "^6.26.0",
    "babel-plugin-dynamic-import-node": "^2.3.3",
    "babel-preset-es2015": "^6.24.1",
    "conventional-changelog-cli": "^2.2.2",
    "core-js": "^3.37.0",
    "crypto-js": "^4.1.1",
    "dayjs": "^1.10.8",
    "echarts": "^5.4.2",
    "element-ui": "2.15.9",
    "es-abstract": "^1.22.5",
    "file-saver": "^2.0.5",
    "html-webpack-plugin": "^5.5.0",
    "js-cookie": "2.2.1",
    "js-md5": "^0.7.3",
    "jsencrypt": "3.0.0-rc.1",
    "jsonlint": "1.6.3",
    "nprogress": "0.2.0",
    "screenfull": "5.0.2",
    "standard-version": "^9.5.0",
    "throttle-debounce": "1.1.0",
    "vue": "^2.7.14",
    "vue-cropper": "^0.5.5",
    "vue-meta": "^2.4.0",
    "vue-router": "^3.4.9",
    "vue-template-compiler": "^2.6.14",
    "vue3-dnd": "^2.0.4",
    "vuedraggable": "^2.24.3",
    "vuex": "^3.6.0",
    "wl-gantt": "^1.0.6",
    "zc-framework-ui": "^2.1.46"
  },
  "devDependencies": {
    "@vue/cli-plugin-babel": "^5.0.8",
    "@vue/cli-plugin-eslint": "^5.0.8",
    "@vue/cli-service": "^5.0.8",
    "@vuepress/plugin-back-to-top": "^1.9.7",
    "babel-core": "^6.26.3",
    "babel-eslint": "10.1.0",
    "bundle-loader": "^0.5.6",
    "chalk": "^5.0.1",
    "compression-webpack-plugin": "^10.0.0",
    "eslint": "7.15.0",
    "eslint-plugin-vue": "7.2.0",
    "node-polyfill-webpack-plugin": "^2.0.1",
    "sass": "1.32.13",
    "sass-loader": "10.0.2",
    "script-ext-html-webpack-plugin": "2.1.5",
    "script-loader": "0.7.2",
    "svg-sprite-loader": "5.1.1",
    "webpack": "^5.88.2",
    "webpack-bundle-analyzer": "^4.9.1",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^4.15.1",
    "webpack-merge": "^5.9.0",
    "webpackbar": "^5.0.2"
  },
  "engines": {
    "node": ">=8.9",
    "npm": ">= 3.0.0"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions"
  ]
}
